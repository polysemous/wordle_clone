# Local development uses a safe mock identity and in-memory demo data.
DATA_BACKEND=memory
ALLOW_DEV_AUTH=true
DEV_USER_EMAIL=player@example.com
DEV_USER_NAME=Your Name

# Production values (set on Cloud Run; never commit secrets).
# DATA_BACKEND=firestore
# GOOGLE_CLOUD_PROJECT=your-project-id
# IAP_AUDIENCE=/projects/PROJECT_NUMBER/locations/REGION/services/SERVICE_NAME
# PUZZLE_SEED=set-a-stable-secret-before-the-first-puzzle
# PUZZLE_TIME_ZONE=America/New_York
# PUZZLE_EPOCH=2026-01-01
# A temporary override must include its exact Eastern calendar date.
# PUZZLE_TODAY_OVERRIDE=field
# PUZZLE_TODAY_OVERRIDE_DATE=2026-07-15
